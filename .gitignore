# --- ZironSec Personal/Private Assets ---
# This rule ignores any file with "-PRIVATE" in the name.
# Use this for your bank notes, tax strategies, and master plans.
*-PRIVATE.*
docs/finance/
docs/legal/
docs/operations/Compliance/
docs/operations/Fedramp/
docs/operations/remediation-templates-PRIVATE/
# Backup rule: catch anything with 'Compliance' regardless of case
[Cc]ompliance/

# --- AI & MCP Secrets ---
# Keeps your AI 'skills' from leaking your keys
.env
.env.*
mcp-secrets.json
.vscode/mcp-secrets.json

# --- Secrets Vault ---
# Block all real secret files, allow only .example templates
security/secrets/**
!security/secrets/**/.env.*.example

# --- OS / IDE Junk ---
.DS_Store
Thumbs.db
.vscode/*.log
*.tmp

# --- Development Trash ---
node_modules/
__pycache__/
dist/
build/

# Ignore local environment settings (API keys, etc.)
src/Website/.env
src/Website/config-PRIVATE.js

# Ignore specific draft pages you aren't ready to show
src/Website/drafts/
src/Website/*-PRIVATE.html

# Ignore VSCode workspace settings (personal preferences)
.vscode/